
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * ARENA STORAGE RULES v1.0
     * Secure asset management for playmaker identities.
     */

    match /avatars/{userId}/{allPaths=**} {
      // Profile pictures are publicly viewable
      allow read: if true;
      
      // Only the owner can upload or change their avatar
      // Limits size to 1MB to keep the arena fast
      allow write: if request.auth != null && 
                   request.auth.uid == userId && 
                   request.resource.size < 1 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    // Global Deny-All for non-specified paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
