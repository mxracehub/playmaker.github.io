
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ARENA SECURITY CORE v1.2
     * Resolved: auth/firebase-app-check-token-is-invalid
     * Public read is allowed for lobby stats.
     * Write access is strictly tied to authenticated identity.
     */

    match /games/{gameId} {
      // Explicitly allow public read (get and list) for lobby dashboard
      allow read: if true;
      
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creatorId || 
        request.auth.uid == resource.data.opponentId
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.creatorId
      );
    }

    match /userProfiles/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /adminRoles/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list, create, update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
