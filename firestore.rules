
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ARENA SECURITY RULES v10.0
     * Explicit public visibility for lobby stats and admin-only controls.
     */

    match /games/{gameId} {
      // Explicitly allow public read (get and list) for lobby stats
      allow read: if true;
      
      // Only registered playmakers can issue challenges
      allow create: if request.auth != null;
      
      // Participants or Admins for updates
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creatorId || 
        request.auth.uid == resource.data.opponentId ||
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Only initiators or Admins can scrap a challenge
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.creatorId ||
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /userProfiles/{userId} {
      // Profiles are readable for social discovery
      allow get: if true;
      allow list: if request.auth != null;
      
      // Users can manage their own profiles; Admins can manage any profile
      allow create, update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Only Admins can delete profiles
      allow delete: if request.auth != null && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';
    }

    match /sports/{sportId} {
      allow read: if true;
    }

    match /events/{eventId} {
      allow read: if true;
    }

    // Standard fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
