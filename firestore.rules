
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /users/{userId}/wallet/{walletId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // In a real app, only admin or creator could update specific fields
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // Reference data
    match /sports/{id} { allow read: if true; }
    match /leagues/{id} { allow read: if true; }
    match /teams/{id} { allow read: if true; }
    match /athletes/{id} { allow read: if true; }
  }
}
