
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ARENA SECURITY RULES v4.0
     * Explicitly allows public listing and getting of games to resolve lobby errors.
     */

    match /games/{gameId} {
      // Allow everyone to list and get games for the lobby/dashboard
      allow get, list: if true;
      
      // Only registered playmakers can issue challenges
      allow create: if request.auth != null;
      
      // Participants only for game state updates (accepting/playing)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creatorId || 
        request.auth.uid == resource.data.opponentId
      );
      
      // Only the initiator can scrap a challenge
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.creatorId
      );
    }

    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow get: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Standard fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
