
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ARENA SECURITY RULES v5.0
     * Optimized for high-fidelity prototype verification and public lobby transparency.
     */

    match /games/{gameId} {
      // Shorthand for get and list - allows anyone to see the arena floor stats
      allow read: if true;
      
      // Only registered playmakers can issue challenges
      allow create: if request.auth != null;
      
      // Participants only for game state updates (accepting/playing)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creatorId || 
        request.auth.uid == resource.data.opponentId
      );
      
      // Only the initiator can scrap a challenge
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.creatorId
      );
    }

    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      // Profiles are publicly readable for social discovery in the arena
      allow get: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Standard fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
